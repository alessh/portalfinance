# Portal Finance — environment variable reference
# Copy to .env.local for local development.
# Never commit .env.local — it is listed in .gitignore.

# --- Core ---
DATABASE_URL=postgresql://user:password@localhost:5432/portal_finance
NEXTAUTH_SECRET=                              # >= 32 chars; openssl rand -base64 48
NEXTAUTH_URL=http://localhost:3000
ENCRYPTION_KEY=                              # base64-encoded 32 bytes; openssl rand -base64 32
CPF_HASH_PEPPER=                             # >= 32 chars; HMAC pepper for CPF uniqueness hash

# --- Observability (Sentry EU — de.sentry.io) ---
SENTRY_DSN=                                  # https://<key>@<org>.ingest.de.sentry.io/<project>
SENTRY_ENV=development

# --- Cloudflare Turnstile ---
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- AWS SES ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
SES_FROM_EMAIL=no-reply@portalfinance.app

# --- Phase 2: Pluggy ingestion ---
PLUGGY_ENV=sandbox
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_WEBHOOK_SECRET=                       # >=32 chars; AWS SSM SecureString in prod
PLUGGY_SANDBOX_CLIENT_ID=
PLUGGY_SANDBOX_CLIENT_SECRET=
PLUGGY_ITEM_ID_HASH_PEPPER=                  # >=32 chars; HMAC pepper for pluggy_item_id_hash (distinct from CPF_HASH_PEPPER, RESEARCH OQ#6)
